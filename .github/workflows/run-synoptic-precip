name: Update precip data

on:
  schedule:
    - cron: "*/5 * * * *"
  workflow_dispatch:

permissions:
  contents: write

jobs:
  refresh:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install requests python-dateutil

      - name: Fetch Synoptic precip (pmode=last)
        env:
          SYNOPTIC_TOKEN: ${{ secrets.SYNOPTIC_TOKEN }}   # <-- secret injected into env
          STATIONS: "TT917,TT918,AR247,023HI"
          OUTPUT_JSON: "data/latestPrecip.json"
        run: |
          python scripts/fetch_precip.py

      - name: Commit & push updated data
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add data/latestPrecip.json
          git commit -m "Update precip data [skip ci]" || echo "No changes to commit"
          git push
